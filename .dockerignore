# 5.8: keep the docker context lean. Anything that ends up in the
# build context becomes a layer hash input, so we exclude
# everything not needed inside the image.

# Local environments / virtualenvs
.env
.venv/
venv/
env/

# Python bytecode caches
__pycache__/
*.py[cod]
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Tooling state
.git/
.github/
.gitignore
.pre-commit-config.yaml

# Local databases / WAL sidecars / caches
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
api_cache.db.sqlite

# Logs / progress files / per-run state
*.log
*_log.txt
progress_*.json
checkpoint_*.json
stop_*.flag

# Project artifacts the runtime container doesn't need
pars.zip
rutor_check_*.html
rutor_test.html
temp_csv_head.txt
IMDBOCENKI.csv
kinopoiskocenki.csv

# Docs / dev-only bits. `*.md` catches REVIEW.md, ROADMAP.md,
# AGENTS.md, etc. README.md ships inside the image.
*.md
!README.md

# Tests don't run inside the production image
tests/

# Editor / OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db

# Tooling configs only matter for dev
pyproject.toml
requirements.in
requirements-dev.in

# Frontend (ROADMAP Stage 10.1) — Node artifacts. The frontend source is
# still needed inside the build context for the `frontend-builder` stage to
# run `npm ci && npm run build`; only the derivative caches are excluded.
# `frontend/dist` is filled by COPY --from=frontend-builder in the runtime
# stage, so excluding it here keeps stale local builds out of the context.
frontend/node_modules/
frontend/dist/
frontend/.vite/
