{
  "sync": {
    "page_depth": 20,
    "stop_threshold": 5,
    "default_period_days": 30,
    "request_delay": 0.3
  },
  "reprocess": {
    "batch_size": 100,
    "request_delay": 0.5
  },
  "fix_posters": {
    "batch_size": 300,
    "request_delay": 0.5
  },
  "rezka": {
    "request_delay": 0.5
  },
  "rutor": {
    "max_retries": 3,
    "retry_delay_base": 5
  },
  "shutdown": {
    "graceful_timeout": 5
  },
  "cache": {
    "backend": "sqlite",
    "db_path": "api_cache.db",
    "expire_hours": 168,
    "allowable_methods": ["GET"],
    "match_headers": ["Authorization", "X-API-KEY"]
  }
}
