# ------------------------------------------------------------------------
# par2 — environment variables template
# par2 — шаблон переменных окружения
#
# Copy this file to `.env` (NOT committed; covered by .gitignore) and fill
# in the values you need. Anything left blank/unset is treated as "not
# configured" by the app.
# [RU] Скопируйте этот файл в `.env` (он НЕ коммитится — учтён в .gitignore)
# и заполните нужные значения. Любое пустое/незаданное значение
# приложение считает «не настроено».
#
# IMPORTANT: never commit `.env` to git, never paste it into chat, log it,
# or screenshot it. The values below grant full access to your tracker
# accounts and external API quotas.
# [RU] ВАЖНО: никогда не коммитьте `.env` в git, не вставляйте его в чат,
# не логируйте и не делайте скриншотов. Значения ниже дают полный
# доступ к вашим аккаунтам и квотам внешних API.
# ------------------------------------------------------------------------


# ── Web UI authentication / Авторизация веб-интерфейса ─────────────────
#
# When BOTH AUTH_USER is set AND (AUTH_PASS or AUTH_PASS_HASH) is set, the
# /api/* HTTP endpoints AND the /ws WebSocket require a Bearer token
# obtained via POST /api/login. When neither is set, the app runs without
# authentication — only do that on a strictly local network.
# [RU] Если заданы И AUTH_USER, И (AUTH_PASS или AUTH_PASS_HASH), то все
# эндпоинты /api/* И WebSocket /ws требуют Bearer-токен, полученный
# через POST /api/login. Если не задано ничего — приложение работает
# без авторизации — делайте так только в строго локальной сети.
#
# AUTH_PASS_HASH (preferred): a pbkdf2_sha256-encoded hash. Generate one
# with the one-liner below; it never leaves your machine and the result
# can safely be checked into a private secrets manager.
# [RU] AUTH_PASS_HASH (предпочтительно): хеш в формате pbkdf2_sha256.
# Сгенерируйте его командой ниже; пароль не покидает вашу машину, а
# результат можно безопасно хранить в менеджере секретов.
#
#   python -c "import hashlib,base64,secrets,sys; pw=sys.argv[1]; \
#     salt=secrets.token_bytes(16); \
#     h=hashlib.pbkdf2_hmac('sha256', pw.encode(), salt, 600_000); \
#     print('pbkdf2_sha256\$600000\$'+base64.b64encode(salt).decode()+'\$' \
#           +base64.b64encode(h).decode())" 'your-password'
#
# AUTH_PASS (fallback): plaintext password. Kept for backward compat —
# prefer AUTH_PASS_HASH in production. Only used when AUTH_PASS_HASH is
# not set.
# [RU] AUTH_PASS (запасной вариант): пароль открытым текстом. Оставлен
# для совместимости — в продакшене используйте AUTH_PASS_HASH.
# Используется только когда AUTH_PASS_HASH не задан.
AUTH_USER=
AUTH_PASS_HASH=
AUTH_PASS=


# ── HDRezka credentials / Учётные данные HDRezka ───────────────────────
#
# Used by rezka_sync.py and rezka_collections_sync.py to log in and pull
# your watched/collection state.
# [RU] Используются rezka_sync.py и rezka_collections_sync.py для входа
# и выгрузки ваших просмотренных/коллекций.
#
# RECOMMENDED: register a SEPARATE "service" account on HDRezka, just for
# par2. Do NOT use your personal HDRezka account credentials here.
# [RU] РЕКОМЕНДУЕТСЯ: заведите ОТДЕЛЬНЫЙ «сервисный» аккаунт на
# HDRezka только для par2. НЕ используйте здесь данные личного
# аккаунта. Так, если `.env` утечёт, вы сможете сменить только
# один этот аккаунт, не трогая настоящий.
REZKA_EMAIL=
REZKA_PASSWORD=

# Number of concurrent rezka_sync requests. Default is 6.
# [RU] Количество одновременных запросов rezka_sync. По умолчанию 6.
# Поднимите до 8–10, если сеть/аккаунт тянет; снизьте до 3–4 при
# появлении капчи/пустых ответов. Разово: `python rezka_sync.py --concurrency N`.
REZKA_CONCURRENCY=


# ── External APIs / Внешние API ───────────────────────────────────
# All are optional; missing keys disable the corresponding lookup.
# [RU] Все ключи необязательны; без ключа соответствующий источник
# метаданных просто отключается.
KINOPOISK_API_KEY=
POISKKINO_API_KEY=
TMDB_API_KEY=
# TMDB_API_TOKEN: v4 Read Access Token (preferred over v3 API_KEY).
# [RU] TMDB_API_TOKEN: токен доступа v4 (предпочтительнее v3 API_KEY).
TMDB_API_TOKEN=


# ── kino.pub integration / Интеграция с kino.pub ─────────────────────
#
# kino.pub provides an official JSON API (https://kinoapi.com). par2 talks
# to it via OAuth Device Flow: the UI shows a short user_code, you visit the
# verification URI in your browser, type the code, and par2 stores the
# access_token + refresh_token in app_data.db's `kinopub_auth` table.
# [RU] kino.pub предоставляет официальный JSON API (https://kinoapi.com).
# par2 работает через OAuth Device Flow: интерфейс покажет короткий
# user_code, вы открываете страницу подтверждения в браузере, вводите
# код, и par2 сохраняет access_token + refresh_token в таблице
# `kinopub_auth` в app_data.db.
#
# KINOPUB_ENABLED toggles the integration entirely (default "false").
# [RU] KINOPUB_ENABLED полностью вкл/выкл интеграцию (по умолчанию "false").
#
# KINOPUB_CLIENT_ID / KINOPUB_CLIENT_SECRET: OAuth "application
# credentials" (NOT your login). Leave blank to use the well-known
# Kodi "xbmc" defaults; override only if you have your own pair.
# [RU] KINOPUB_CLIENT_ID / KINOPUB_CLIENT_SECRET: OAuth-данные «приложения»
# (ЭТО НЕ ваш логин). Оставьте пустыми для использования
# стандартных Kodi-значений "xbmc"; переопределяйте только если
# у вас есть своя пара.
#
# KINOPUB_IGNORED_FOLDERS: comma-separated kino.pub folders to skip on sync.
# [RU] KINOPUB_IGNORED_FOLDERS: папки kino.pub через запятую, которые
# пропускать при синхронизации.
KINOPUB_ENABLED=false
KINOPUB_IGNORED_FOLDERS=max,lena

# Trakt.tv API credentials (for importing history/ratings)
# [RU] Данные API Trakt.tv (для импорта истории/оценок)
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret
KINOPUB_CLIENT_ID=
KINOPUB_CLIENT_SECRET=


# ── Sync window / Окно синхронизации ─────────────────────────────
# Optional: restrict sync_job to a year range. Leave empty for all years.
# [RU] Необязательно: ограничить sync_job диапазоном лет. Пусто —
# все годы.
SYNC_MIN_YEAR=
SYNC_MAX_YEAR=


# ── Rutor mirror / Зеркало Rutor ───────────────────────────────
# Override the Rutor host par2 talks to. Default is HTTPS. Switch to a
# regional mirror or http:// only if the default is unreachable.
# [RU] Переопределить хост Rutor. По умолчанию HTTPS. Меняйте на
# региональное зеркало или http:// только если дефолт недоступен.
# RUTOR_MIRROR=https://rutor.info


# ── Internal (rarely overridden) / Внутреннее (редко меняют) ───────────
# STATUS_KEY is set by the app itself when it spawns a subprocess.
# [RU] STATUS_KEY приложение выставляет само при запуске подпроцесса;
# вручную в .env его обычно не нужно указывать.
# STATUS_KEY=


# ── Lampa.mx Catalog Integration / Интеграция каталога Lampa.mx ──────
# LAMPA_ENABLED: master switch for Lampa.mx integration (default: true).
# LAMPA_API_KEY: optional key required in X-API-Key header or `key` query
# param for external TV devices. Leave blank for public home-network access.
# [RU] LAMPA_ENABLED: главный переключатель интеграции Lampa.mx
# (по умолчанию true). LAMPA_API_KEY: необязательный ключ в заголовке
# X-API-Key или параметре `key` для внешних TV-устройств. Пусто —
# открытый доступ в домашней сети.
LAMPA_ENABLED=true
LAMPA_API_KEY=


# ── Cloud sync (Turso / libSQL) / Облачная синхронизация ─────────
# Stage 13 — optional whole-DB mirror to a Turso (libSQL) cloud database so
# the tracker can be restored on another machine. Requires the optional
# `libsql` package: `pip install libsql` (see requirements.in).
# [RU] Stage 13 — необязательное зеркалирование всей БД в облако
# Turso (libSQL), чтобы восстановить трекер на другой машине.
# Требует пакет `libsql`: `pip install libsql` (см. requirements.in).
#
# CLOUD_PROVIDER: "none" (default) disables; "turso" enables it.
# CLOUD_TURSO_URL: your database URL, e.g. libsql://your-db.turso.io
# CLOUD_TURSO_TOKEN: the database auth token (sensitive — never commit).
# CLOUD_SYNC_ON_STARTUP: pull the remote copy on boot (default: true).
# CLOUD_SYNC_AFTER_JOB: push after each sync job completes (default: true).
# CLOUD_SYNC_INTERVAL_MINUTES: background push interval, minutes (default 15).
# [RU] CLOUD_PROVIDER: "none" (по умолчанию) отключает; "turso" включает.
# CLOUD_TURSO_URL: URL базы, напр. libsql://your-db.turso.io
# CLOUD_TURSO_TOKEN: токен доступа (секрет — не коммитить).
# CLOUD_SYNC_ON_STARTUP: тянуть копию при старте (по умолчанию true).
# CLOUD_SYNC_AFTER_JOB: пушить после каждой синхронизации (true).
# CLOUD_SYNC_INTERVAL_MINUTES: интервал фонового пуша, мин (15).
CLOUD_PROVIDER=none
CLOUD_TURSO_URL=
CLOUD_TURSO_TOKEN=
CLOUD_SYNC_ON_STARTUP=true
CLOUD_SYNC_AFTER_JOB=true
CLOUD_SYNC_INTERVAL_MINUTES=15


# ── Per-service proxies / Посервисные прокси ────────────────────
# Stage 14 — optionally route each upstream source through its own proxy so
# region-locked trackers stay reachable. Each value is a full proxy URL and
# may be left blank to use a direct connection.
# [RU] Stage 14 — при желании пропустить каждый источник через свой
# прокси, чтобы регионально заблокированные трекеры оставались
# доступны. Каждое значение — полный URL прокси; пусто — прямое
# соединение.
#
# Также эти значения можно задать через фронтенд: Админ-панель →
# раздел «Прокси» (сохраняется в .env и перечитывается на лету).
#
# Supported schemes per entry / Поддерживаемые схемы:
#   http://user:pass@host:port
#   socks5://user:pass@host:port   (requires `pip install PySocks`)
#   vless://...                    (spawns a local SOCKS proxy via Xray/
#                                   sing-box — set XRAY_BINARY below)
#
# XRAY_BINARY: path to the xray (or sing-box) executable used to bridge
# vless:// links into a local SOCKS proxy. Defaults to "xray" on PATH.
# [RU] XRAY_BINARY: путь к исполняемому файлу xray (или sing-box) для
# преобразования vless://-ссылок в локальный SOCKS-прокси.
# По умолчанию "xray" из PATH.
PROXY_REZKA=
PROXY_KINOPUB=
PROXY_RUTOR=
PROXY_TMDB=
PROXY_KINOPOISK=
PROXY_POISKKINO=
XRAY_BINARY=xray
