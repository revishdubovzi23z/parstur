# ------------------------------------------------------------------------
# par2 — environment variables template
#
# Copy this file to `.env` (NOT committed; covered by .gitignore) and fill
# in the values you need. Anything left blank/unset is treated as "not
# configured" by the app.
#
# IMPORTANT: never commit `.env` to git, never paste it into chat, log it,
# or screenshot it. The values below grant full access to your tracker
# accounts and external API quotas.
# ------------------------------------------------------------------------


# ── Web UI authentication ───────────────────────────────────────────────
#
# When BOTH AUTH_USER is set AND (AUTH_PASS or AUTH_PASS_HASH) is set, the
# /api/* HTTP endpoints AND the /ws WebSocket require a Bearer token
# obtained via POST /api/login. When neither is set, the app runs without
# authentication — only do that on a strictly local network.
#
# AUTH_PASS_HASH (preferred): a pbkdf2_sha256-encoded hash. Generate one
# with the one-liner below; it never leaves your machine and the result
# can safely be checked into a private secrets manager.
#
#   python -c "import hashlib,base64,secrets,sys; pw=sys.argv[1]; \
#     salt=secrets.token_bytes(16); \
#     h=hashlib.pbkdf2_hmac('sha256', pw.encode(), salt, 600_000); \
#     print('pbkdf2_sha256\$600000\$'+base64.b64encode(salt).decode()+'\$' \
#           +base64.b64encode(h).decode())" 'your-password'
#
# AUTH_PASS (fallback): plaintext password. Kept for backward compat —
# prefer AUTH_PASS_HASH in production. Only used when AUTH_PASS_HASH is
# not set.
AUTH_USER=
AUTH_PASS_HASH=
AUTH_PASS=


# ── HDRezka credentials ─────────────────────────────────────────────────
#
# Used by rezka_sync.py and rezka_collections_sync.py to log in and pull
# your watched/collection state.
#
# RECOMMENDED: register a SEPARATE "service" account on HDRezka, just for
# par2. Do NOT use your personal HDRezka account credentials here. The
# service account should:
#   * have its own email
#   * have a unique password (not reused anywhere)
#   * keep the watched/favourites you want to mirror, but nothing
#     personally identifying
# This way, if your `.env` ever leaks (compromised dev box, accidentally
# committed snapshot, shoulder-surfed during a screenshare), you can
# rotate just that one account without affecting your real one.
REZKA_EMAIL=
REZKA_PASSWORD=

# Number of concurrent rezka_sync requests. Default is 6 (was 3 before
# 4.4); rezka tolerates this comfortably with a logged-in session.
# Bump to 8-10 if your network/account can handle it; drop to 3-4 if
# you start seeing captcha/empty-search responses. Override on a
# single run with `python rezka_sync.py --concurrency N`.
REZKA_CONCURRENCY=


# ── External APIs ───────────────────────────────────────────────────────
# All three are optional; missing keys disable the corresponding lookup.
KINOPOISK_API_KEY=
POISKKINO_API_KEY=
TMDB_API_KEY=
# TMDB_API_TOKEN: v4 Read Access Token (preferred over v3 API_KEY).
TMDB_API_TOKEN=


# ── kino.pub integration ────────────────────────────────────────────────
#
# kino.pub provides an official JSON API (https://kinoapi.com) used by
# Kodi/Roku/Forkplayer plugins. par2 talks to it via OAuth Device Flow:
# the UI shows you a short user_code, you visit KINOPUB_DEVICE_VERIFICATION_URI
# in your normal browser (where you log into kino.pub as usual, including
# 2FA), type the code, and par2 receives an access_token + refresh_token
# stored in app_data.db's `kinopub_auth` table.
#
# KINOPUB_ENABLED toggles the integration entirely. Default is "false" so a
# fresh install doesn't try to authenticate before you've signed up.
#
# KINOPUB_CLIENT_ID / KINOPUB_CLIENT_SECRET: the OAuth "application
# credentials". This is NOT your kino.pub login — it identifies par2 to
# the API. The defaults are the well-known "xbmc" credentials embedded in
# the open-source Kodi addon (quarckster/kodi.kino.pub) and many other
# clients. They work for personal use. If you obtained your own pair from
# support@kino.pub, override them here.
KINOPUB_ENABLED=false
KINOPUB_CLIENT_ID=
KINOPUB_CLIENT_SECRET=


# ── Sync window ─────────────────────────────────────────────────────────
# Optional: restrict sync_job to a year range. Leave empty for all years.
SYNC_MIN_YEAR=
SYNC_MAX_YEAR=


# ── Rutor mirror ────────────────────────────────────────────────────────
# Override the Rutor host par2 talks to. Default is HTTPS so credentials
# (cookies, future POSTs) and traffic don't traverse the local network in
# plaintext. Switch to a regional mirror or http:// only if you know the
# default is unreachable from your network.
# RUTOR_MIRROR=https://rutor.info


# ── Internal (rarely overridden) ────────────────────────────────────────
# STATUS_KEY is set by the app itself when it spawns a subprocess; you do
# not normally need to put it in .env.
# STATUS_KEY=
